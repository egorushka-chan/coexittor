@using CoExittor.Common.Models
@using System.Security.Claims
@*
    Вывод всех событий
*@
@model List<Event>
@{
    ViewData["Title"] = "События";
    long myID = Accessor.HttpContext?.User.Claims.Where(c => ClaimTypes.NameIdentifier == c.Type).Select(c => long.Parse(c.Value)).First() ?? 0;
}

<div class="container">
    <h1 class="mb-3">@ViewData["Title"]</h1>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">
            Событий пока нет.
        </div>
        return;
    }

    <h4 class="mt-3">События</h4>
    <div class="row g-3 mt-1">
        @foreach (var e in Model)
        {
            var part = e.Participants.Where(p => p.IsHost).First();
            
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card border-success shadow-sm">
                    <div class="card-body bg-light">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title mb-1">@e.Name</h5>
                        </div>

                        <div class="text-muted small mb-2">
                            Код: <code>@e.Code</code>
                            @if (part.LinkedUserID == myID)
                            {
                                <span class="badge bg-primary ms-1">моё</span>
                            }
                        </div>

                        <ul class="list-unstyled small mb-3">
                            @if (part.Votings is not null && part.Votings.Count > 0)
                            {
                                <li class="text-muted small">
                                    @foreach (var v in part.Votings)
                                    {
                                        <div>@v.StartDate.ToString("yyyy-MM-dd HH:mm") — @v.EndDate.ToString("yyyy-MM-dd HH:mm")</div>
                                    }
                                </li>
                            }
                        </ul>

                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-outline-primary"
                                asp-controller="Events"
                                asp-action="Details"
                                asp-route-code="@e.Code">
                                Открыть
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

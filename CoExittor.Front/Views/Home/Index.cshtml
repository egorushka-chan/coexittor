@{
    ViewData["Title"] = "CoExittor";
}

<div class="row">
    <div class="col-lg-8">
        <h1 class="mb-3">CoExittor</h1>
        <p class="text-muted">
            Минимальный фронт для демонстрации backend: создать событие → поделиться кодом → присоединиться → посмотреть результат.
        </p>

        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Открыть событие по коду</h5>

                <form asp-action="OpenEvent" method="post" class="row g-2">
                    @Html.AntiForgeryToken()
                    <div class="col-md-8">
                        <input class="form-control" name="code" placeholder="GUID-код события (например: 2f4c...)" />
                    </div>
                    <div class="col-md-4 d-grid">
                        <button class="btn btn-primary" type="submit">Открыть</button>
                    </div>
                </form>

                <div class="mt-3">
                    <a class="btn btn-outline-secondary" asp-controller="Events" asp-action="Create">Создать событие</a>
                </div>
            </div>
        </div>
    </div>
</div>
